# Backend environment variables
# Copy to `.env` and fill with real values; do NOT commit `.env` with secrets.

# Application port
PORT=5000

# MongoDB connection string (example for local dev)
# Use a production connection string from your secrets manager in production
MONGODB_URI=mongodb://username:password@localhost:27017/your_database

# JWT secrets (use long random values)
JWT_SECRET=change_this_to_a_long_random_string
JWT_REFRESH_SECRET=change_this_to_another_long_random_string

# Optional default password used for imported faculty records
DEFAULT_FACULTY_PASSWORD=Test1234!

# Rate limiting (numbers)
RATE_LIMIT_MAX=100
AUTH_RATE_LIMIT_MAX=50

# Comma-separated list of allowed origins for CORS
CORS_ORIGINS=http://localhost:5173